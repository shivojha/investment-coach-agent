# Copy to .env and fill in values for local development
USE_LOCAL_SECRETS=true

# Azure OpenAI
AOAI_ENDPOINT=https://<your-resource>.openai.azure.com/
AOAI_API_KEY=<your-key>
AOAI_CHAT_DEPLOYMENT=gpt-4o
AOAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small

# Azure AI Search
AI_SEARCH_ENDPOINT=https://<your-resource>.search.windows.net
AI_SEARCH_KEY=<your-key>
AI_SEARCH_INDEX=user-profiles

# Azure Cosmos DB
COSMOS_CONNECTION=AccountEndpoint=https://<your-resource>.documents.azure.com:443/;AccountKey=<key>;
COSMOS_DATABASE=investment-coach
COSMOS_CONTAINER=chat-history

# Azure Entra ID
ENTRA_TENANT_ID=<your-tenant-id>
ENTRA_CLIENT_ID=<your-client-id>
